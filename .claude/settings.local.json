{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git -c user.name=DaCompta -c user.email=dev@dacompta.local commit -q -m 'docs: spec de design — incrément 1 Plan comptable *)",
      "Bash(git -c user.name=DaCompta -c user.email=dev@dacompta.local commit -q -m 'docs: plan d'\\''implémentation — incrément Plan comptable *)",
      "Bash(npx create-next-app@latest . --ts --app --eslint --no-tailwind --import-alias \"@/*\" --use-npm --skip-install)",
      "Bash(mkdir -p src)",
      "Bash(mv app *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(git commit *)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(node --input-type=module --experimental-strip-types)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"session_start\\\",\\\"dir\\\":\\\"$CLAUDE_PROJECT_DIR\\\"}\" >> .claude/logs/activity.jsonl"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"tool_use\\\",\\\"tool\\\":\\\"$CLAUDE_TOOL_NAME\\\",\\\"files\\\":\\\"$CLAUDE_FILE_PATHS\\\"}\" >> .claude/logs/activity.jsonl"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"event\\\":\\\"stop\\\"}\" >> .claude/logs/activity.jsonl"
          }
        ]
      }
    ]
  }
}
