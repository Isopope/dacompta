generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Referentiel {
  id       String    @id @default(cuid())
  code     String    @unique // "SYSCOHADA_REVISE"
  libelle  String
  classes  Classe[]
  natures  Nature[]
  dossiers Dossier[]
}

model Classe {
  id            String      @id @default(cuid())
  numero        Int // 1..9
  libelle       String
  referentiel   Referentiel @relation(fields: [referentielId], references: [id])
  referentielId String

  @@unique([referentielId, numero])
}

model Nature {
  id            String      @id @default(cuid())
  racine        String // "40", "6", ...
  libelle       String
  famille       String // TIERS | CAPITAUX | TRESORERIE | GESTION | IMMO | STOCK
  reportNplus1  Boolean
  referentiel   Referentiel @relation(fields: [referentielId], references: [id])
  referentielId String

  @@unique([referentielId, racine])
}

model Dossier {
  id               String           @id @default(cuid())
  nom              String
  ville            String
  pays             String
  devise           String
  exercice         Int
  // Verrous de période façon Odoo : soft lock (réversible) et hard lock
  // (irréversible — clôture définitive). Interdisent toute écriture dont la date
  // est antérieure ou égale au verrou.
  fiscalyearLockDate DateTime?
  hardLockDate       DateTime?
  referentiel      Referentiel      @relation(fields: [referentielId], references: [id])
  referentielId    String
  comptes          Compte[]
  imports          ImportLog[]
  journaux         Journal[]
  pieces           Piece[]
  budgetPostes     BudgetPoste[]
  soldesAnterieurs SoldeAnterieur[]
  lettrages        Lettrage[]
  reglesLettrage   RegleLettrage[]
  tiers            Tiers[]
  taxes            Taxe[]
  paiements        Paiement[]
  auditLogs        AuditLog[]
}

// Journal d'audit (équivalent piste d'audit / mail.thread d'Odoo) : trace les
// opérations sensibles (validation, annulation, extourne, verrou) de façon append-only.
model AuditLog {
  id        String   @id @default(cuid())
  dossier   Dossier  @relation(fields: [dossierId], references: [id])
  dossierId String
  type      String // CREATION | VALIDATION | ANNULATION | EXTOURNE | VERROU
  pieceId   String?
  message   String
  createdAt DateTime @default(now())

  @@index([dossierId])
}

// Paiement (équivalent account.payment d'Odoo). Génère une pièce de trésorerie
// équilibrée et se lettre automatiquement contre les factures du tiers.
model Paiement {
  id           String   @id @default(cuid())
  dossier      Dossier  @relation(fields: [dossierId], references: [id])
  dossierId    String
  tiers        Tiers    @relation(fields: [tiersId], references: [id], onDelete: Restrict)
  tiersId      String
  pieceId      String?  @unique
  piece        Piece?   @relation("PaiementPiece", fields: [pieceId], references: [id])
  sens         String // ENTRANT (encaissement client) | SORTANT (décaissement fournisseur)
  montant      Decimal  @default(0)
  datePaiement DateTime
  etat         String   @default("posted") // draft | posted
  createdAt    DateTime @default(now())

  @@index([dossierId])
}

// Taxe (équivalent account.tax d'Odoo). Mono-taux. `usage` = type_tax_use
// (sale/purchase) ; `exigibilite` = tax_exigibility (sur facture / sur encaissement).
model Taxe {
  id           String          @id @default(cuid())
  dossier      Dossier         @relation(fields: [dossierId], references: [id])
  dossierId    String
  code         String // ex. "TVA18", "TVA18-ACH"
  nom          String
  taux         Decimal         @default(0) // pourcentage, ou montant fixe si typeAmount=fixed
  typeAmount   String          @default("percent") // percent | fixed
  usage        String // sale | purchase
  priceInclude Boolean         @default(false)
  exigibilite  String          @default("sur_facture") // sur_facture | sur_encaissement
  compteNumero String // compte de TVA (443x collectée / 445x déductible)
  active       Boolean         @default(true)
  lignes       LigneEcriture[]
  createdAt    DateTime        @default(now())

  @@unique([dossierId, code])
  @@index([dossierId])
}

// Tiers (équivalent res.partner d'Odoo) : client/fournisseur rattaché à un dossier,
// porteur d'un code auxiliaire. Le lettrage et le grand-livre auxiliaire se font
// par (compte collectif, tiers).
model Tiers {
  id        String          @id @default(cuid())
  dossier   Dossier         @relation(fields: [dossierId], references: [id])
  dossierId String
  code      String // code auxiliaire (ex. "C001", "F042")
  nom       String
  type      String // CLIENT | FOURNISSEUR | AUTRE
  lignes    LigneEcriture[]
  paiements Paiement[]
  createdAt DateTime        @default(now())

  @@unique([dossierId, code])
  @@index([dossierId])
}

model Compte {
  id               String           @id @default(cuid())
  numero           String // 6 chiffres
  intitule         String
  type             String // DETAIL | TOTAL
  classeNum        Int
  natureRacine     String?
  reportNplus1     Boolean
  collectif        Boolean          @default(false)
  // Type de compte façon Odoo account_type (asset_receivable, liability_payable,
  // asset_cash, equity, income, expense…). Porte le comportement comptable.
  accountType      String           @default("off_balance")
  // Réconciliable (Odoo account.reconcile) : seuls les comptes réconciliables
  // peuvent être lettrés. Vrai par défaut pour receivable/payable.
  reconciliable    Boolean          @default(false)
  statut           String           @default("ACTIF") // ACTIF | ARCHIVE
  dossier          Dossier          @relation(fields: [dossierId], references: [id])
  dossierId        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lignes           LigneEcriture[]
  soldesAnterieurs SoldeAnterieur[]

  @@unique([dossierId, numero])
}

model ImportLog {
  id            String   @id @default(cuid())
  dossier       Dossier  @relation(fields: [dossierId], references: [id])
  dossierId     String
  fichierNom    String
  mode          String // FUSIONNER | REMPLACER | AJOUTER
  snapshotAvant String // JSON des comptes avant import
  compteIds     String // JSON array des ids créés/modifiés
  annule        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Journal {
  id        String  @id @default(cuid())
  code      String // ACH | VT | CAI | BIMA | OD | PE | RAN
  libelle   String
  type      String  @default("misc") // sale | purchase | cash | bank | misc
  dossier   Dossier @relation(fields: [dossierId], references: [id])
  dossierId String
  pieces    Piece[]

  @@unique([dossierId, code])
}

model Piece {
  id              String          @id @default(cuid())
  numeroPiece     String
  datePiece       DateTime
  fournisseur     String?
  montantHT       Decimal         @default(0)
  montantTVA      Decimal         @default(0)
  montantTTC      Decimal         @default(0)
  statut          String          @default("BROUILLON") // BROUILLON | VALIDEE | ANNULEE
  journal         Journal         @relation(fields: [journalId], references: [id])
  journalId       String
  dossier         Dossier         @relation(fields: [dossierId], references: [id])
  dossierId       String
  lignes          LigneEcriture[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  exercice        Int?
  dateValidation  DateTime?
  hash            String?
  hashPrecedent   String?
  extourneDeId    String?
  extourneDe      Piece?          @relation("Extourne", fields: [extourneDeId], references: [id])
  extournes       Piece[]         @relation("Extourne")
  paiement        Paiement?       @relation("PaiementPiece")

  @@unique([dossierId, numeroPiece])
}

model BudgetPoste {
  id        String   @id @default(cuid())
  code      String // ex. "605300"
  libelle   String // ex. "Achat carburant"
  sens      String // "P" (Produit/recette) ou "C" (Charge/dépense)
  prevision Decimal  @default(0)
  compteLie String // préfixe compte (ex. "605", "706")
  dossier   Dossier  @relation(fields: [dossierId], references: [id])
  dossierId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dossierId, code])
}

// Solde de clôture N-1 par compte (snapshot de l'exercice précédent).
// Signé débit − crédit, comme `ouverture`. Source du N-1 pour le Compte de
// résultat (les classes 6/7 n'ont pas de RAN). Le Bilan, lui, garde son N-1
// déduit du RAN.
model SoldeAnterieur {
  id           String   @id @default(cuid())
  compteNumero String // référence Compte.numero (pas de FK formelle)
  montant      Decimal  @default(0) // solde N-1 signé débit − crédit
  dossier      Dossier  @relation(fields: [dossierId], references: [id])
  dossierId    String
  compteId     String?
  compte       Compte?  @relation(fields: [compteId], references: [id], onDelete: Restrict)

  @@unique([dossierId, compteNumero])
}

model LigneEcriture {
  id                String  @id @default(cuid())
  piece             Piece   @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  pieceId           String
  compteNumero      String // référence Compte.numero (redondant avec la FK, conservé pour lisibilité)
  libelleLigne      String
  debit             Decimal @default(0)
  credit            Decimal @default(0)
  // Solde signé (debit − credit), source unique façon Odoo (account.move.line.balance).
  // Peuplé par le code applicatif à la création (debit/credit sont immuables ensuite).
  balance           Decimal @default(0)
  ordre             Int
  sectionAnalytique String? // section analytique optionnelle
  compteId          String
  compte            Compte  @relation(fields: [compteId], references: [id], onDelete: Restrict)
  // Tiers (auxiliaire) — requis sur les lignes de comptes collectifs (401/411…),
  // null sinon. Équivalent partner_id d'Odoo.
  tiersId           String?
  tiers             Tiers?  @relation(fields: [tiersId], references: [id], onDelete: Restrict)
  // Taxe ayant généré cette ligne de taxe (équivalent tax_line_id d'Odoo). Null
  // pour les lignes ordinaires.
  taxeId            String?
  taxe              Taxe?   @relation(fields: [taxeId], references: [id], onDelete: Restrict)

  // Lettrage (inspiré d'Odoo amount_residual). amountResidual = montant restant
  // à lettrer sur la ligne, en valeur absolue (initialisé à |débit − crédit|).
  // isLettres passe à true quand le résiduel atteint 0. On ne touche JAMAIS
  // debit/credit : seuls amountResidual/isLettres reflètent le lettrage.
  amountResidual  Decimal    @default(0)
  isLettres       Boolean    @default(false)
  lettragesDebit  Lettrage[] @relation("LettrageDebit")
  lettragesCredit Lettrage[] @relation("LettrageCredit")

  @@index([pieceId])
}

// Lettrage : rapprochement partiel entre une ligne débit et une ligne crédit du
// même compte de tiers (équivalent AccountPartialReconcile d'Odoo).
model Lettrage {
  id            String        @id @default(cuid())
  dossier       Dossier       @relation(fields: [dossierId], references: [id])
  dossierId     String
  ligneDebit    LigneEcriture @relation("LettrageDebit", fields: [ligneDebitId], references: [id], onDelete: Cascade)
  ligneDebitId  String
  ligneCredit   LigneEcriture @relation("LettrageCredit", fields: [ligneCreditId], references: [id], onDelete: Cascade)
  ligneCreditId String
  montant       Decimal       @default(0) // montant lettré (toujours > 0)
  auto          Boolean       @default(false) // créé par une règle automatique
  createdAt     DateTime      @default(now())

  @@index([dossierId])
  @@index([ligneDebitId])
  @@index([ligneCreditId])
}

// Règle de lettrage automatique (inspirée des reconciliation models d'Odoo).
model RegleLettrage {
  id             String   @id @default(cuid())
  dossier        Dossier  @relation(fields: [dossierId], references: [id])
  dossierId      String
  nom            String
  prefixeCompte  String // comptes de tiers ciblés (ex. "411", "401")
  tolerancePct   Float    @default(0) // écart de montant accepté en % (ex. 10)
  toleranceJours Int      @default(0) // écart de date accepté en jours (ex. 30)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([dossierId])
}

model SequencePiece {
  id            String @id @default(cuid())
  dossierId     String
  journalId     String
  exercice      Int
  dernierNumero Int    @default(0)

  @@unique([dossierId, journalId, exercice])
}
