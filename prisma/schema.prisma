generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Referentiel {
  id       String    @id @default(cuid())
  code     String    @unique // "SYSCOHADA_REVISE"
  libelle  String
  classes  Classe[]
  natures  Nature[]
  dossiers Dossier[]
}

model Classe {
  id            String      @id @default(cuid())
  numero        Int // 1..9
  libelle       String
  referentiel   Referentiel @relation(fields: [referentielId], references: [id])
  referentielId String

  @@unique([referentielId, numero])
}

model Nature {
  id            String      @id @default(cuid())
  racine        String // "40", "6", ...
  libelle       String
  famille       String // TIERS | CAPITAUX | TRESORERIE | GESTION | IMMO | STOCK
  reportNplus1  Boolean
  referentiel   Referentiel @relation(fields: [referentielId], references: [id])
  referentielId String

  @@unique([referentielId, racine])
}

model Dossier {
  id               String           @id @default(cuid())
  nom              String
  ville            String
  pays             String
  devise           String
  exercice         Int
  referentiel      Referentiel      @relation(fields: [referentielId], references: [id])
  referentielId    String
  comptes          Compte[]
  imports          ImportLog[]
  journaux         Journal[]
  pieces           Piece[]
  budgetPostes     BudgetPoste[]
  soldesAnterieurs SoldeAnterieur[]
  lettrages        Lettrage[]
  reglesLettrage   RegleLettrage[]
}

model Compte {
  id           String   @id @default(cuid())
  numero       String // 6 chiffres
  intitule     String
  type         String // DETAIL | TOTAL
  classeNum    Int
  natureRacine String?
  reportNplus1 Boolean
  collectif    Boolean  @default(false)
  statut       String   @default("ACTIF") // ACTIF | ARCHIVE
  dossier      Dossier  @relation(fields: [dossierId], references: [id])
  dossierId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([dossierId, numero])
}

model ImportLog {
  id            String   @id @default(cuid())
  dossier       Dossier  @relation(fields: [dossierId], references: [id])
  dossierId     String
  fichierNom    String
  mode          String // FUSIONNER | REMPLACER | AJOUTER
  snapshotAvant String // JSON des comptes avant import
  compteIds     String // JSON array des ids créés/modifiés
  annule        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Journal {
  id        String  @id @default(cuid())
  code      String // ACH | VT | CAI | BIMA | OD | PE | RAN
  libelle   String
  dossier   Dossier @relation(fields: [dossierId], references: [id])
  dossierId String
  pieces    Piece[]

  @@unique([dossierId, code])
}

model Piece {
  id          String          @id @default(cuid())
  numeroPiece String
  datePiece   DateTime
  fournisseur String?
  montantHT   Decimal         @default(0)
  montantTVA  Decimal         @default(0)
  montantTTC  Decimal         @default(0)
  statut      String          @default("BROUILLON") // BROUILLON | VALIDEE | ANNULEE
  journal     Journal         @relation(fields: [journalId], references: [id])
  journalId   String
  dossier     Dossier         @relation(fields: [dossierId], references: [id])
  dossierId   String
  lignes      LigneEcriture[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([dossierId, numeroPiece])
}

model BudgetPoste {
  id        String   @id @default(cuid())
  code      String // ex. "605300"
  libelle   String // ex. "Achat carburant"
  sens      String // "P" (Produit/recette) ou "C" (Charge/dépense)
  prevision Decimal  @default(0)
  compteLie String // préfixe compte (ex. "605", "706")
  dossier   Dossier  @relation(fields: [dossierId], references: [id])
  dossierId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dossierId, code])
}

// Solde de clôture N-1 par compte (snapshot de l'exercice précédent).
// Signé débit − crédit, comme `ouverture`. Source du N-1 pour le Compte de
// résultat (les classes 6/7 n'ont pas de RAN). Le Bilan, lui, garde son N-1
// déduit du RAN.
model SoldeAnterieur {
  id           String  @id @default(cuid())
  compteNumero String // référence Compte.numero (pas de FK formelle)
  montant      Decimal @default(0) // solde N-1 signé débit − crédit
  dossier      Dossier @relation(fields: [dossierId], references: [id])
  dossierId    String

  @@unique([dossierId, compteNumero])
}

model LigneEcriture {
  id                String  @id @default(cuid())
  piece             Piece   @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  pieceId           String
  compteNumero      String // référence Compte.numero (pas de FK formelle)
  libelleLigne      String
  debit             Decimal @default(0)
  credit            Decimal @default(0)
  ordre             Int
  sectionAnalytique String? // section analytique optionnelle

  // Lettrage (inspiré d'Odoo amount_residual). amountResidual = montant restant
  // à lettrer sur la ligne, en valeur absolue (initialisé à |débit − crédit|).
  // isLettres passe à true quand le résiduel atteint 0. On ne touche JAMAIS
  // debit/credit : seuls amountResidual/isLettres reflètent le lettrage.
  amountResidual  Decimal    @default(0)
  isLettres       Boolean    @default(false)
  lettragesDebit  Lettrage[] @relation("LettrageDebit")
  lettragesCredit Lettrage[] @relation("LettrageCredit")

  @@index([pieceId])
}

// Lettrage : rapprochement partiel entre une ligne débit et une ligne crédit du
// même compte de tiers (équivalent AccountPartialReconcile d'Odoo).
model Lettrage {
  id            String        @id @default(cuid())
  dossier       Dossier       @relation(fields: [dossierId], references: [id])
  dossierId     String
  ligneDebit    LigneEcriture @relation("LettrageDebit", fields: [ligneDebitId], references: [id], onDelete: Cascade)
  ligneDebitId  String
  ligneCredit   LigneEcriture @relation("LettrageCredit", fields: [ligneCreditId], references: [id], onDelete: Cascade)
  ligneCreditId String
  montant       Decimal       @default(0) // montant lettré (toujours > 0)
  auto          Boolean       @default(false) // créé par une règle automatique
  createdAt     DateTime      @default(now())

  @@index([dossierId])
  @@index([ligneDebitId])
  @@index([ligneCreditId])
}

// Règle de lettrage automatique (inspirée des reconciliation models d'Odoo).
model RegleLettrage {
  id             String   @id @default(cuid())
  dossier        Dossier  @relation(fields: [dossierId], references: [id])
  dossierId      String
  nom            String
  prefixeCompte  String // comptes de tiers ciblés (ex. "411", "401")
  tolerancePct   Float    @default(0) // écart de montant accepté en % (ex. 10)
  toleranceJours Int      @default(0) // écart de date accepté en jours (ex. 30)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([dossierId])
}
